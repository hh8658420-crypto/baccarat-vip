*{box-sizing:border-box;-webkit-tap-highlight-color:transparent;user-select:none}
html,body{margin:0;width:100%;min-height:100%;background:#111;font-family:-apple-system,BlinkMacSystemFont,"PingFang SC",Arial,sans-serif}
body{display:flex;justify-content:center;color:white}
.phone{width:100%;max-width:430px;min-height:100vh;background:#1b0206;overflow:hidden}

.topbar{
  height:58px;background:#fafafa;color:#222;display:grid;
  grid-template-columns:42px 42px 1fr auto;align-items:center;gap:8px;
  padding:0 10px;font-weight:800
}
.icon{border:0;background:none;font-size:28px;color:#333}
.room-title{font-size:20px;text-align:center}
.balance{background:#f7f1e1;border-radius:18px;padding:6px 10px;color:#333}

.dealer-screen{
  height:310px;position:relative;overflow:hidden;background:#8e7253
}
.casino-bg{
  position:absolute;inset:0;
  background:
    radial-gradient(circle at 20% 30%,rgba(255,255,255,.25),transparent 18%),
    radial-gradient(circle at 75% 20%,rgba(255,255,255,.2),transparent 16%),
    linear-gradient(140deg,#b29368,#7b5d42 45%,#4d372a);
}
.casino-bg:before{
  content:"";position:absolute;inset:0;
  background:
    repeating-linear-gradient(90deg,transparent 0 42px,rgba(255,255,255,.08) 43px 45px),
    repeating-linear-gradient(0deg,transparent 0 42px,rgba(0,0,0,.08) 43px 45px);
  opacity:.5
}
.dealer-card{
  position:absolute;left:50%;bottom:48px;transform:translateX(-50%);
  width:190px;height:210px;border-radius:100px 100px 18px 18px;
  background:linear-gradient(#fff,#e9e9e9);
  box-shadow:0 8px 28px rgba(0,0,0,.45);
  display:flex;flex-direction:column;align-items:center;justify-content:center
}
.dealer-face{font-size:92px;animation:float 2.4s ease-in-out infinite}
.dealer-tag{background:#1e2240;color:#fff;border-radius:20px;padding:4px 12px;font-size:12px;font-weight:800}
.table-sign{
  position:absolute;right:22px;bottom:78px;background:#1e2240;color:#ffdf7e;
  padding:8px 10px;border-radius:4px;border:1px solid #c89a3c;font-size:12px;text-align:center
}
.table-sign span{display:block;color:#fff;font-size:10px;margin-top:2px}
.hand-display{
  position:absolute;left:0;right:0;bottom:0;height:76px;
  background:linear-gradient(180deg,rgba(126,9,22,.75),rgba(96,5,14,.96));
  display:grid;grid-template-columns:1fr 1fr;align-items:center;text-align:center
}
.hand-display span{font-size:12px;color:#ffd7a2}
.cards{min-height:36px}
.card{
  display:inline-flex;align-items:center;justify-content:center;
  width:34px;height:46px;background:white;color:#111;border-radius:6px;
  margin:2px;font-weight:900;font-size:15px;
  box-shadow:0 4px 10px rgba(0,0,0,.45);animation:cardIn .25s ease
}
.card.red{color:#c9152d}

.bet-panel{
  background:linear-gradient(180deg,#a7192a,#74101c);
  border-radius:16px 16px 0 0;margin-top:-4px;position:relative;z-index:5;
  padding:8px 8px 10px;border:1px solid rgba(255,255,255,.15)
}
.round-info{
  height:34px;display:grid;grid-template-columns:1fr auto 1fr;align-items:center;
  font-size:12px;color:#ffd6d6
}
.round-info strong{
  width:44px;height:44px;border-radius:50%;background:#c85461;
  display:flex;align-items:center;justify-content:center;color:white;font-size:20px;margin-top:-12px
}
.tips-row{display:grid;grid-template-columns:repeat(5,1fr);gap:1px;margin-top:4px}
.tips-row div{
  background:rgba(60,0,10,.46);min-height:58px;padding:5px 2px;
  color:#ffd08a;font-size:13px;font-weight:800;text-align:center
}
.tips-row span{display:block;color:#66d8ff;font-size:9px;margin-top:3px;font-weight:600}
.main-bets{display:grid;grid-template-columns:1fr 1fr 1fr;gap:1px}
.bet-box{
  height:122px;border:0;background:rgba(115,10,23,.9);color:white;
  position:relative;font-weight:900
}
.bet-box small{
  position:absolute;right:12px;top:12px;width:36px;height:36px;border-radius:50%;
  border:1px solid rgba(255,255,255,.3);display:flex;align-items:center;justify-content:center;
  background:rgba(255,255,255,.12)
}
.bet-box b{display:block;font-size:48px;line-height:54px}
.bet-box span{font-size:28px}
.bet-box.player b,.bet-box.player span{color:#4fd2ff}
.bet-box.tie b,.bet-box.tie span{color:#70ffbb}
.bet-box.banker b,.bet-box.banker span{color:#ffd09a}
.bet-box.active{outline:3px solid #ffd86b;z-index:3;filter:brightness(1.15)}

.action-row{display:grid;grid-template-columns:1fr 1fr;gap:1px;margin-top:1px}
.action-row button{
  height:46px;border:0;background:rgba(90,7,16,.95);color:rgba(255,255,255,.45);
  font-size:18px
}
.message{min-height:28px;margin-top:5px;color:#fff;font-size:14px;font-weight:800;text-align:center}

.chip-bar{
  height:78px;background:#9c1828;display:grid;grid-template-columns:54px 1fr 54px;
  align-items:center;padding:0 8px;border-bottom:6px solid #2b2b2b
}
.side-btn{height:44px;border:0;border-radius:8px;background:rgba(255,255,255,.12);color:white;font-weight:800}
.chips{display:flex;justify-content:space-around;align-items:center}
.chip{
  width:54px;height:54px;border-radius:50%;border:0;color:white;font-weight:900;font-size:16px;
  box-shadow:0 5px 12px rgba(0,0,0,.42)
}
.c10{background:radial-gradient(circle,#eee 0 25%,#263547 26% 58%,#d8c17e 59% 66%,#1b1b1b 67%)}
.c20{background:radial-gradient(circle,#ffe6b0 0 25%,#d65b3f 26% 58%,#ffe6b0 59% 66%,#9b271b 67%)}
.c50{background:radial-gradient(circle,#fff3ad 0 25%,#32bde8 26% 58%,#fff3ad 59% 66%,#0780a6 67%)}
.c100{background:radial-gradient(circle,#fff3ad 0 25%,#8c4cff 26% 58%,#fff3ad 59% 66%,#5624b2 67%)}
.c200{background:radial-gradient(circle,#fff3ad 0 25%,#2bb2b7 26% 58%,#fff3ad 59% 66%,#107a80 67%)}
.chip.active{transform:translateY(-8px);outline:3px solid #ffd86b}

.road-tabs{
  height:46px;background:#333;display:grid;grid-template-columns:1fr 1fr 1fr;gap:1px
}
.road-tabs button{border:0;background:#3b3b3b;color:#ddd;font-size:15px;font-weight:800}
#dealBtn{background:#ffd86b;color:#111}

.roads{background:white;color:#111;padding:6px 8px 18px}
.stat-line{display:flex;gap:12px;font-size:13px;margin-bottom:6px;align-items:center}
.road-wrap{display:grid;grid-template-columns:90px 1fr;gap:8px}
.bead-road{
  display:grid;grid-template-columns:repeat(3,26px);grid-auto-rows:26px;gap:3px
}
.big-road{
  display:grid;grid-template-columns:repeat(13,18px);grid-auto-rows:18px;gap:3px;align-content:start
}
.dot{
  border-radius:50%;display:flex;align-items:center;justify-content:center;color:white;
  font-size:12px;font-weight:900
}
.dot.player{background:#1181ff}.dot.banker{background:#e31b35}.dot.tie{background:#13ba70}
.big-dot{border-radius:50%;background:white;border:3px solid}
.big-dot.player{border-color:#1181ff}.big-dot.banker{border-color:#e31b35}.big-dot.tie{border-color:#13ba70;background:#13ba70}

@keyframes cardIn{from{transform:rotateY(90deg);opacity:0}to{transform:rotateY(0);opacity:1}}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-5px)}}

@media (orientation:landscape){
  .phone{max-width:100%;display:grid;grid-template-columns:1fr 390px;grid-template-rows:58px 1fr 124px}
  .topbar{grid-column:1/3}
  .dealer-screen{height:auto;grid-column:1;grid-row:2}
  .bet-panel{grid-column:2;grid-row:2;margin-top:0;border-radius:0}
  .chip-bar{grid-column:2;grid-row:3}
  .road-tabs{grid-column:1;grid-row:3}
  .roads{grid-column:1;grid-row:4}
}
