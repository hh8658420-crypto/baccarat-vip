*{
  box-sizing:border-box;
  -webkit-tap-highlight-color:transparent;
  user-select:none;
}

html,body{
  margin:0;
  width:100%;
  min-height:100%;
  background:#050b08;
  color:white;
  font-family:-apple-system,BlinkMacSystemFont,"PingFang SC",Arial,sans-serif;
  overflow-x:hidden;
}

body{
  background:
    radial-gradient(circle at 50% 0%, rgba(255,216,107,.18), transparent 28%),
    radial-gradient(circle at 20% 20%, rgba(0,255,170,.12), transparent 24%),
    radial-gradient(circle at 80% 15%, rgba(255,80,80,.13), transparent 26%),
    linear-gradient(180deg,#06100c,#020403 70%);
}

.app{
  max-width:1200px;
  min-height:100vh;
  margin:auto;
  padding:10px;
}

.topbar{
  height:64px;
  display:grid;
  grid-template-columns:1fr auto auto;
  gap:10px;
  align-items:center;
}

.brand{
  display:flex;
  align-items:center;
  gap:10px;
}

.logo{
  width:44px;
  height:44px;
  border-radius:50%;
  display:flex;
  align-items:center;
  justify-content:center;
  color:#111;
  background:linear-gradient(135deg,#fff3a3,#b88315);
  box-shadow:0 0 20px rgba(255,216,107,.45);
  font-size:24px;
  font-weight:900;
}

.title{
  font-size:19px;
  letter-spacing:1px;
  font-weight:900;
  color:#ffd86b;
}

.sub{
  font-size:11px;
  color:rgba(255,255,255,.62);
}

.wallet{
  min-width:128px;
  border:1px solid rgba(255,216,107,.55);
  border-radius:999px;
  padding:7px 14px;
  background:rgba(0,0,0,.48);
  box-shadow:inset 0 0 16px rgba(255,216,107,.08);
}

.wallet span{
  font-size:12px;
  color:#bbb;
  margin-right:6px;
}

.wallet strong{
  color:#ffd86b;
  font-size:19px;
}

.soundBtn{
  width:44px;
  height:44px;
  border-radius:50%;
  border:1px solid rgba(255,216,107,.5);
  background:#151515;
  color:#ffd86b;
  font-size:20px;
}

.casino{
  display:grid;
  grid-template-columns:1fr 330px;
  gap:12px;
}

.dealerStage{
  grid-column:1 / 2;
  height:130px;
  position:relative;
  display:flex;
  justify-content:center;
  align-items:flex-end;
  overflow:hidden;
}

.light{
  position:absolute;
  top:8px;
  width:190px;
  height:190px;
  filter:blur(20px);
  opacity:.45;
  border-radius:50%;
}

.light.left{
  left:12%;
  background:radial-gradient(circle,#ffd86b,transparent 68%);
}

.light.right{
  right:12%;
  background:radial-gradient(circle,#ff4d6d,transparent 68%);
}

.dealer{
  position:relative;
  width:190px;
  height:124px;
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:flex-end;
}

.dealer:before{
  content:"";
  position:absolute;
  bottom:8px;
  width:150px;
  height:72px;
  border-radius:80px 80px 18px 18px;
  background:linear-gradient(180deg,#121212,#050505);
  border:1px solid rgba(255,216,107,.25);
  box-shadow:0 0 30px rgba(0,0,0,.7);
}

.dealerFace{
  position:relative;
  z-index:2;
  font-size:72px;
  animation:floatDealer 2.8s ease-in-out infinite;
}

.dealerName{
  position:relative;
  z-index:3;
  margin-top:-4px;
  padding:3px 10px;
  border-radius:999px;
  color:#111;
  background:linear-gradient(135deg,#fff0a8,#c99526);
  font-size:12px;
  font-weight:900;
}

.table{
  grid-column:1 / 2;
  position:relative;
  border:5px solid #c6962e;
  border-radius:42px;
  padding:18px;
  background:
    radial-gradient(ellipse at center, rgba(255,255,255,.08), transparent 45%),
    radial-gradient(ellipse at center,#138457,#06301f 78%);
  box-shadow:
    0 22px 60px rgba(0,0,0,.72),
    inset 0 0 70px rgba(255,216,107,.14);
}

.table:after{
  content:"";
  position:absolute;
  inset:14px;
  border-radius:32px;
  border:1px dashed rgba(255,216,107,.26);
  pointer-events:none;
}

.table.winFlash{
  animation:winFlash .8s ease;
}

.tableLogo{
  color:rgba(255,216,107,.32);
  letter-spacing:7px;
  font-size:20px;
  font-weight:900;
  margin-bottom:8px;
}

.hands{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:14px;
}

.handPanel{
  min-height:155px;
  border-radius:24px;
  padding:12px;
  background:rgba(0,0,0,.26);
  border:1px solid rgba(255,255,255,.18);
}

.playerPanel{
  box-shadow:inset 0 0 26px rgba(30,100,255,.18);
}

.bankerPanel{
  box-shadow:inset 0 0 26px rgba(255,40,40,.18);
}

.handTitle{
  font-size:20px;
  font-weight:900;
  margin-bottom:10px;
}

.cards{
  min-height:78px;
}

.card{
  width:54px;
  height:74px;
  margin:4px;
  display:inline-flex;
  align-items:center;
  justify-content:center;
  background:
    linear-gradient(145deg,#fff,#e8e8e8);
  color:#111;
  border-radius:10px;
  font-size:21px;
  font-weight:900;
  box-shadow:0 8px 18px rgba(0,0,0,.55);
  animation:cardIn .28s ease;
}

.card.red{
  color:#c5162c;
}

.score{
  color:#ffd86b;
  font-size:20px;
  font-weight:900;
}

.betZones{
  margin-top:16px;
  display:grid;
  grid-template-columns:1fr 1fr 1fr;
  gap:12px;
}

.betZone{
  min-height:76px;
  border-radius:22px;
  border:2px solid rgba(255,255,255,.25);
  font-size:25px;
  font-weight:900;
  color:white;
  box-shadow:0 10px 22px rgba(0,0,0,.36);
}

.betZone span{
  font-size:12px;
  opacity:.86;
}

.betZone.blue{
  background:linear-gradient(180deg,#1f72ff,#073f9c);
}

.betZone.red{
  background:linear-gradient(180deg,#e33245,#7e0915);
}

.betZone.gold{
  background:linear-gradient(180deg,#ffe58c,#a97008);
  color:#111;
}

.betZone.active{
  outline:4px solid white;
  transform:translateY(-3px) scale(1.02);
}

.chips{
  margin-top:14px;
  display:flex;
  gap:12px;
  flex-wrap:wrap;
  justify-content:center;
}

.chip{
  width:64px;
  height:64px;
  border-radius:50%;
  border:0;
  color:#111;
  font-weight:900;
  background:
    radial-gradient(circle,#fff 0 29%,#d71920 30% 56%,#fff 57% 64%,#111 65%);
  box-shadow:0 8px 18px rgba(0,0,0,.55);
}

.chip.active{
  outline:4px solid #ffd86b;
  transform:translateY(-5px);
}

.controls{
  margin-top:14px;
  display:flex;
  justify-content:center;
  flex-wrap:wrap;
  gap:10px;
}

button{
  cursor:pointer;
  font-family:inherit;
}

.dealBtn,.darkBtn{
  border:0;
  border-radius:16px;
  padding:13px 20px;
  font-size:18px;
  font-weight:900;
}

.dealBtn{
  color:#111;
  background:linear-gradient(180deg,#fff0a8,#c89118);
  box-shadow:0 0 24px rgba(255,216,107,.62);
}

.darkBtn{
  color:#fff;
  background:#161616;
  border:1px solid rgba(255,255,255,.2);
}

.message{
  min-height:44px;
  margin-top:12px;
  font-size:18px;
  font-weight:900;
  color:#fff;
}

.sidePanel{
  grid-column:2 / 3;
  grid-row:1 / span 2;
  display:flex;
  flex-direction:column;
  gap:10px;
}

.statGrid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:8px;
}

.statGrid div{
  background:rgba(0,0,0,.45);
  border:1px solid rgba(255,255,255,.12);
  border-radius:16px;
  padding:10px;
}

.statGrid span{
  display:block;
  font-size:12px;
  color:#aaa;
}

.statGrid strong{
  font-size:22px;
  color:#ffd86b;
}

.roadBox{
  background:rgba(255,255,255,.93);
  color:#111;
  border-radius:18px;
  padding:10px;
}

.roadTitle{
  font-weight:900;
  margin-bottom:8px;
}

.beadRoad,.bigRoad{
  display:grid;
  grid-template-columns:repeat(10, 1fr);
  gap:4px;
}

.bigRoad{
  grid-template-columns:repeat(8, 1fr);
}

.dot{
  aspect-ratio:1;
  border-radius:50%;
  color:white;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:12px;
  font-weight:900;
}

.dot.player{background:#1769ff}
.dot.banker{background:#d71920}
.dot.tie{background:#18a34a}

.bigDot{
  aspect-ratio:1;
  border-radius:50%;
  border:3px solid currentColor;
  background:white;
}

.bigDot.player{color:#1769ff}
.bigDot.banker{color:#d71920}
.bigDot.tie{
  color:#18a34a;
  background:#18a34a;
}

@keyframes cardIn{
  from{transform:translateY(-18px) rotateY(90deg);opacity:0}
  to{transform:translateY(0) rotateY(0);opacity:1}
}

@keyframes floatDealer{
  0%,100%{transform:translateY(0)}
  50%{transform:translateY(-6px)}
}

@keyframes winFlash{
  0%{box-shadow:0 0 0 gold}
  50%{box-shadow:0 0 65px gold}
  100%{box-shadow:0 22px 60px rgba(0,0,0,.72)}
}

@media (max-width:900px){
  .casino{
    grid-template-columns:1fr;
  }

  .sidePanel{
    grid-column:1;
    grid-row:auto;
  }

  .dealerStage{
    height:110px;
  }
}

@media (orientation:landscape) and (max-height:520px){
  .topbar{height:48px}
  .dealerStage{height:78px}
  .dealerFace{font-size:48px}
  .dealer{height:78px}
  .dealer:before{height:46px}
  .table{padding:10px;border-radius:30px}
  .handPanel{min-height:104px;padding:8px}
  .card{width:42px;height:56px;font-size:17px}
  .betZone{min-height:54px;font-size:20px}
  .chip{width:48px;height:48px}
  .dealBtn,.darkBtn{padding:9px 14px;font-size:15px}
  .message{min-height:28px;font-size:14px}
}
